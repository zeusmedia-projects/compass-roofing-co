    right: 0;
    width: 55%;
    height: 100%;
    background: linear-gradient(135deg, rgba(34, 81, 163, 0.18) 0%, rgba(27, 58, 107, 0.08) 100%);
    border-left: 1px solid rgba(196, 200, 212, 0.08);
}

.cover-compass {
    width: 56px;
    height: 56px;
    margin-bottom: 40px;
    opacity: 0.9;
}

.cover-eyebrow {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal-amber);
    margin-bottom: 20px;
}

.cover h1 {
    font-size: 52px;
    font-weight: 800;
    line-height: 1.08;
    color: #fff;
    max-width: 620px;
    margin-bottom: 24px;
    letter-spacing: -0.02em;
}

.cover h1 span {
    color: var(--sky-blue);
}

.cover-sub {
    font-size: 17px;
