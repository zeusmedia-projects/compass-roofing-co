    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    display: block;
    margin-bottom: 4px;
}

.cover-meta-item span {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    font-weight: 500;
}

/* ── LAYOUT ── */
.doc-body {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 48px 120px;
}

/* ── CHAPTER HEADER ── */
.chapter {
    padding: 80px 0 0;
    border-top: 2px solid var(--compass-blue);
    margin-top: 80px;
}

.chapter:first-of-type {
    margin-top: 0;
    border-top: none;
}

.chapter-num {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--signal-amber);
    margin-bottom: 12px;
}

.chapter h2 {
    font-size: 32px;
    font-weight: 800;
    color: var(--compass-blue);
    letter-spacing: -0.02em;
    margin-bottom: 8px;
    line-height: 1.1;
}

.chapter-sub {
    font-size: 15px;
    color: var(--text-muted);
    margin-bottom: 40px;
    max-width: 640px;
}

/* ── SECTION HEADER ── */
.section-head {
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--compass-blue);
    margin: 48px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-light);
}

/* ── PROSE ── */
p {
    margin-bottom: 16px;
    color: var(--body-text);
}

p:last-child {
    margin-bottom: 0;
}

strong {
    font-weight: 700;
    color: var(--compass-blue);
}

/* ── CALLOUT BLOCK ── */
.callout {
    background: rgba(27, 58, 107, 0.05);
    border-left: 3px solid var(--compass-blue);
    padding: 20px 24px;
    border-radius: 0 8px 8px 0;
    margin: 24px 0;
}

.callout.amber {
    background: rgba(212, 135, 10, 0.06);
    border-left-color: var(--signal-amber);
}

.callout.dark {
    background: var(--storm-charcoal);
    border-left-color: var(--sky-blue);
    color: rgba(255, 255, 255, 0.8);
}

.callout.dark strong {
    color: var(--sky-blue);
}

.callout-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--signal-amber);
    margin-bottom: 8px;
}

.callout p {
    margin-bottom: 0;
}

/* ── GRID CARDS ── */
.card-grid {
    display: grid;
    gap: 16px;
    margin: 24px 0;
}

.card-grid.col2 {
    grid-template-columns: 1fr 1fr;
}

.card-grid.col3 {
    grid-template-columns: 1fr 1fr 1fr;
}

.card-grid.col4 {
    grid-template-columns: 1fr 1fr 1fr 1fr;
}

.card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 20px 22px;
}

.card-dark {
    background: var(--storm-charcoal);
    border: 1px solid rgba(196, 200, 212, 0.1);
    border-radius: 10px;
    padding: 20px 22px;
    color: rgba(255, 255, 255, 0.85);
}

.card h4,
.card-dark h4 {
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 8px;
    letter-spacing: -0.01em;
}

.card h4 {
    color: var(--compass-blue);
}

.card-dark h4 {
    color: var(--sky-blue);
}

.card p {
    font-size: 13px;
    color: var(--text-muted);
    margin: 0;
}

.card-dark p {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.5);
}

/* ── COLOR SWATCHES ── */
.palette {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin: 24px 0;
}

.swatch {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 100px;
}

.swatch-color {
    width: 100%;
    height: 52px;
    border-radius: 8px;
    border: 1px solid rgba(0, 0, 0, 0.08);
}

.swatch-label {
    font-size: 11px;
    font-weight: 600;
    color: var(--body-text);
    line-height: 1.3;
}

.swatch-hex {
    font-size: 10px;
    color: var(--text-muted);
    font-family: monospace;
}

/* ── TYPOGRAPHY SAMPLES ── */
.type-sample {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 28px 32px;
    margin: 16px 0;
}

.type-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 12px;
}

.type-display {
    font-family: 'Montserrat', 'Segoe UI', sans-serif;
    font-size: 42px;
    font-weight: 800;
    color: var(--compass-blue);
    letter-spacing: -0.025em;
    line-height: 1.05;
}

.type-h2 {
    font-family: 'Montserrat', 'Segoe UI', sans-serif;
    font-size: 26px;
    font-weight: 700;
    color: var(--compass-blue);
    margin-top: 16px;
}

.type-body-sample {
    font-size: 15px;
    color: var(--body-text);
    line-height: 1.7;
    margin-top: 12px;
}

/* ── SITEMAP TREE ── */
.sitemap {
    margin: 24px 0;
}

.sitemap-root {
    background: var(--compass-blue);
    color: #fff;
    padding: 10px 18px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
    display: inline-block;
    margin-bottom: 12px;
}

.sitemap-branch {
    margin-left: 28px;
    border-left: 2px solid var(--border-medium);
    padding-left: 20px;
}

.sitemap-branch+.sitemap-branch {
    margin-top: 8px;
}

.sitemap-page {
    font-size: 12px;
    color: var(--text-muted);
    padding: 4px 0;
    display: flex;
    align-items: center;
    gap: 6px;
}

.sitemap-page::before {
    content: '';
    width: 8px;
    height: 1px;
    background: var(--border-medium);
    flex-shrink: 0;
}

.sitemap-branch-head {
    font-size: 12px;
    font-weight: 700;
    color: var(--compass-blue);
    margin: 12px 0 4px;
}

/* ── PAGE WIREFRAME ── */
.wireframe {
    background: var(--soft-gray);
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 24px;
    margin: 24px 0;
    font-size: 12px;
    color: var(--text-muted);
}

.wf-bar {
    background: var(--storm-charcoal);
    height: 44px;
    border-radius: 6px;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 11px;
    gap: 12px;
}

.wf-hero {
    background: linear-gradient(135deg, #111318 0%, #1B3A6B 100%);
    height: 180px;
    border-radius: 6px;
    margin-bottom: 4px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px;
    color: rgba(255, 255, 255, 0.8);
}

.wf-hero-h1 {
    font-size: 18px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 6px;
}

.wf-hero-sub {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
}

.wf-cta-row {
    display: flex;
    gap: 8px;
}

.wf-cta-primary {
    background: var(--signal-amber);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    padding: 6px 14px;
    border-radius: 4px;
}

.wf-cta-ghost {
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: rgba(255, 255, 255, 0.7);
    font-size: 10px;
    padding: 6px 14px;
    border-radius: 4px;
}

.wf-proof {
    height: 48px;
    background: #fff;
    border-radius: 6px;
    margin-bottom: 4px;
    display: flex;
    align-items: center;
    justify-content: space-around;
    padding: 0 16px;
    border: 1px solid var(--border-light);
}

.wf-proof-item {
    text-align: center;
}

.wf-proof-val {
    font-size: 13px;
    font-weight: 800;
    color: var(--compass-blue);
}

.wf-proof-lbl {
    font-size: 9px;
    color: var(--text-muted);
}

.wf-section {
    background: #fff;
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 4px;
    border: 1px solid var(--border-light);
}

.wf-section-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 8px;
}

.wf-cards {
    display: flex;
    gap: 6px;
}

.wf-card {
    flex: 1;
    height: 56px;
    background: var(--soft-gray);
    border-radius: 4px;
    border: 1px solid var(--border-light);
}

.wf-dark-section {
    background: var(--storm-charcoal);
    border-radius: 6px;
    padding: 16px;
    margin-bottom: 4px;
    color: rgba(255, 255, 255, 0.5);
    font-size: 10px;
}

/* ── LOGO CONCEPTS ── */
.logo-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin: 24px 0;
}

.logo-concept {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.logo-concept-dark {
    background: var(--deep-charcoal);
    border: 1px solid rgba(196, 200, 212, 0.1);
    border-radius: 10px;
    padding: 28px;
}

.logo-concept-label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-top: 16px;
}

.logo-concept-name {
    font-size: 14px;
    font-weight: 700;
    color: var(--compass-blue);
    margin-top: 4px;
}

/* ── CTA COMPONENTS ── */
.btn-primary {
    display: inline-block;
    background: var(--signal-amber);
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    padding: 12px 24px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    letter-spacing: 0.01em;
    margin-right: 8px;
}

.btn-secondary {
    display: inline-block;
    background: transparent;
    color: var(--compass-blue);
    font-size: 13px;
    font-weight: 700;
    padding: 11px 24px;
    border-radius: 6px;
    border: 2px solid var(--compass-blue);
    cursor: pointer;
}

.btn-ghost-light {
    display: inline-block;
    background: transparent;
    color: rgba(255, 255, 255, 0.85);
    font-size: 13px;
    font-weight: 600;
    padding: 11px 24px;
    border-radius: 6px;
    border: 1.5px solid rgba(255, 255, 255, 0.3);
    cursor: pointer;
}

/* ── SEO PILLAR ── */
.seo-pillar {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    overflow: hidden;
    margin: 16px 0;
}

.seo-pillar-head {
    background: var(--compass-blue);
    padding: 12px 20px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.seo-pillar-head span {
    font-size: 13px;
    font-weight: 700;
    color: #fff;
}

.seo-pillar-body {
    padding: 16px 20px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
}

.kw-tag {
    font-size: 12px;
    color: var(--text-muted);
    background: var(--soft-gray);
    padding: 4px 10px;
    border-radius: 4px;
    display: inline-block;
}

/* ── PROCESS STEP ── */
.process-steps {
    counter-reset: step;
    margin: 24px 0;
}

.process-step {
    display: flex;
    gap: 20px;
    margin-bottom: 20px;
}

.step-num {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--compass-blue);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 2px;
}

.step-body h4 {
    font-size: 14px;
    font-weight: 700;
    color: var(--compass-blue);
    margin-bottom: 4px;
}

.step-body p {
    font-size: 13px;
    margin: 0;
}

/* ── TAG ── */
.tag {
    display: inline-block;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 3px;
    margin-right: 4px;
}

.tag-blue {
    background: rgba(27, 58, 107, 0.1);
    color: var(--compass-blue);
}

.tag-amber {
    background: rgba(212, 135, 10, 0.1);
    color: var(--signal-amber);
}

.tag-gray {
    background: var(--soft-gray);
    color: var(--text-muted);
}

/* ── LIST ── */
.check-list {
    list-style: none;
    margin: 16px 0;
}

.check-list li {
    padding: 7px 0 7px 26px;
    position: relative;
    font-size: 14px;
    color: var(--body-text);
    border-bottom: 1px solid var(--border-light);
}

.check-list li:last-child {
    border-bottom: none;
}

.check-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--signal-amber);
    font-weight: 700;
    font-size: 12px;
}

/* ── COPY BLOCK ── */
.copy-block {
    background: var(--storm-charcoal);
    border-radius: 10px;
    padding: 32px 36px;
    margin: 24px 0;
    color: rgba(255, 255, 255, 0.85);
}

.copy-block .eyebrow {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--signal-amber);
    margin-bottom: 12px;
}

.copy-block h3 {
    font-size: 28px;
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
    line-height: 1.15;
}

.copy-block p {
    font-size: 15px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 20px;
    line-height: 1.7;
}

/* ── ANTIGRAVITY PROMPT ── */
.prompt-block {
    background: #0D1117;
    border-radius: 12px;
    padding: 40px 44px;
    margin: 32px 0;
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.82);
    font-family: 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.8;
    white-space: pre-wrap;
    word-break: break-word;
}

.prompt-block .ph {
    color: #79C0FF;
    font-weight: 700;
}

.prompt-block .pk {
    color: #F0883E;
}

.prompt-block .pv {
    color: #A5D6FF;
}

.prompt-block .pc {
    color: rgba(255, 255, 255, 0.3);
    font-style: italic;
}

/* ── DIVIDER ── */
.divider {
    border: none;
    border-top: 1px solid var(--border-light);
    margin: 40px 0;
}

/* ── TABLE OF CONTENTS ── */
.toc {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 10px;
    padding: 28px 32px;
    margin: 40px 0;
}

.toc h3 {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-light);
    margin-bottom: 16px;
}

.toc-items {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
}

.toc-item {
    font-size: 13px;
    color: var(--compass-blue);
    padding: 5px 0;
    display: flex;
    align-items: center;
    gap: 8px;
}

.toc-item .n {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-light);
    min-width: 22px;
}

/* ── METRIC CARDS ── */
.metric-row {
    display: flex;
    gap: 12px;
    margin: 16px 0;
    flex-wrap: wrap;
}

.metric-card {
    background: #fff;
    border: 1px solid var(--border-light);
    border-radius: 8px;
    padding: 16px 20px;
    flex: 1;
    min-width: 120px;
}

.metric-val {
    font-size: 22px;
    font-weight: 800;
    color: var(--compass-blue);
    letter-spacing: -0.02em;
}

.metric-lbl {
    font-size: 11px;
    color: var(--text-muted);
    margin-top: 2px;
}

/* responsive */
@media (max-width: 700px) {
    .cover {
        padding: 48px 28px 48px;
    }

    .cover h1 {
        font-size: 34px;
    }

    .doc-body {
        padding: 0 24px 80px;
    }

    .card-grid.col2,
    .card-grid.col3,
    .card-grid.col4,
    .logo-grid,
    .toc-items {
        grid-template-columns: 1fr;
    }
}

